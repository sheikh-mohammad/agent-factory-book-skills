# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-key-here

# Vector Store (optional - for knowledge assistants)
KNOWLEDGE_VECTOR_STORE_ID=vs_your-vector-store-id

# Assistant ID (optional - if using pre-configured assistant)
ASSISTANT_ID=asst_your-assistant-id

# Frontend Configuration
VITE_CHATKIT_API_DOMAIN_KEY=your-domain-key

# Database (optional - if using database)
DATABASE_URL=postgresql://user:password@localhost:5432/chatkit

# Security (production)
JWT_SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=10
